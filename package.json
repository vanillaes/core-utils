{
  "name": "@vanillaes/core-utils",
  "version": "1.0.5",
  "description": "Cross-Platform POSIX core-utils in JavaScript",
  "keywords": [
    "ecmascript",
    "esm",
    "esmodules",
    "cli",
    "developer-tools",
    "posix",
    "core-utils",
    "cp",
    "rm",
    ""
  ],
  "repository": "https://github.com/vanillaes/core-utils",
  "author": "Evan Plaice <evanplaice@gmail.com> (https://evanplaice.com)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cp-es": "bin/cp-es.js",
    "rm-es": "bin/rm-es.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    },
    "./cp": {
      "import": "./src/cp.js",
      "types": "./src/cp.d.ts"
    },
    "./rm": {
      "import": "./src/rm.js",
      "types": "./src/rm.d.ts"
    }
  },
  "scripts": {
    "test": "esmtk test",
    "lint": "esmtk lint",
    "type": "esmtk type --types node",
    "build": "esmtk typings --types node",
    "clean": "esmtk clean --typings",
    "preview": "esmtk preview",
    "preversion": "npm run test && npm run lint && npm run type",
    "version": "npm run clean && npm run build && git add **/*.d.ts",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@vanillaes/esmtk": "^2.5.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "lint": {
    "ignore": [
      "**/__tests__/**"
    ]
  }
}
